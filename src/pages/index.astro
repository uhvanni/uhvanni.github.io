---
// src/pages/index.astro
import Cat from '../components/cat.astro'
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="https://avatar-cyan.vercel.app/api/pfp/658119375920037897/smallimage" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="ne.ko - coming soon" />
  <title>ne.ko</title>
</head>

<body>
  <div class="scanlines"></div>

  <main>
    <Cat />
  </main>

  <footer>
    <a href="mailto:contact@ne-ko.io" class="email-link">contact@ne-ko.io</a>
    <span class="divider">·</span>
    <span>© 2026 uhvanni</span>
  </footer>

  <style>
    :root {
      --bg: #0a0a0a;
      --fg: #f5f5f5;
      --dim: #888;
      --pixel: 6px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--fg);
      font-family: 'Courier New', Courier, monospace;
      overflow: hidden;
      image-rendering: auto;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      position: relative;
      padding-bottom: 6rem;
    }

    .email-link {
      color: var(--fg);
      text-decoration: none;
      border-bottom: 1px solid var(--dim);
      padding-bottom: 2px;
      transition: all 0.2s ease;
    }

    .email-link:hover {
      color: var(--fg);
      border-bottom-color: var(--fg);
    }

    .divider {
      margin: 0 0.75rem;
      color: var(--dim);`
    }

    /* Subtle scanline effect */
    .scanlines {
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.02) 0px,
        rgba(255, 255, 255, 0.02) 2px,
        transparent 1px,
        transparent 5px
      );
      pointer-events: none;
      z-index: 100;
    }

    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      animation: fadeIn 0.5s ease-out;
    }

    footer {
      padding: 1.5rem;
      text-align: center;
      font-size: 0.75rem;
      color: var(--dim);
      letter-spacing: 0.1em;
    }

    .tagline {
      font-size: 1rem;
      letter-spacing: 0.2em;
      color: var(--dim);
      margin-top: 2rem;
    }

    /* Animations */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes blink {
      50% { opacity: 0; }
    }

    /* Responsive — make cat a bit smaller on mobile */
    @media (max-width: 600px) {
      :root {
        --pixel: 5px;
      }
      .tagline {
        letter-spacing: 0.3em;
        font-size: 0.75rem;
      }
    }
  </style>
</body>
</html>