---
// src/components/WavyText.astro
interface Props {
  text: string;
  delay?: number;
}
const { text, delay = 0.08 } = Astro.props;
const letters = [...text];
---
<span class="wavy">
  {letters.map((char, i) => (
    <span style={`animation-delay: ${i * delay}s`}>
      {char === ' ' ? '\u00A0' : char}
    </span>
  ))}
</span>

<style>
  .wavy > span {
    padding-top: 2rem;
    display: inline-block;
    color: #ff0000;
    animation: bounce 1.2s ease-in-out infinite, rainbow 3s linear infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @keyframes rainbow {
    0% { color: #ff0000; }
    17% { color: #ff9900; }
    33% { color: #ffff00; }
    50% { color: #00cc00; }
    67% { color: #0066ff; }
    83% { color: #9900ff };
    100% { color: #ff0000; }
  }
</style>